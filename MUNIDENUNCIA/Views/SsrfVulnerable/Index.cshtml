@*
    Views/SsrfVulnerable/Index.cshtml
    Página principal del demo SSRF vulnerable (A10)
*@

@{
    ViewData["Title"] = "SSRF Vulnerable - Vista Previa de Enlace (A10)";
}

<div class="container mt-4">
    <div class="alert alert-danger">
        <h4><i class="bi bi-exclamation-triangle-fill"></i> VERSIÓN VULNERABLE — Solo para demostración</h4>
        <p class="mb-0">Este endpoint acepta <strong>cualquier URL</strong> sin validar el destino.</p>
    </div>

    <h2>Vista Previa de Enlace</h2>
    <p>Ingrese una URL para obtener una vista previa del contenido:</p>

    <form method="get" asp-action="VistaPrevia" class="mb-4">
        <div class="input-group">
            <input type="text" name="url" class="form-control"
                   placeholder="https://ejemplo.com o http://localhost:5000/admin..."
                   value="" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-download"></i> Obtener Vista Previa
            </button>
        </div>
    </form>

    <div class="card bg-dark text-white">
        <div class="card-header">URLs de ataque para demostración</div>
        <div class="card-body">
            <p class="text-warning">Un atacante usaría estas URLs para explotar el SSRF:</p>
            <ul class="list-unstyled font-monospace small">
                <li class="mb-1">• <code>http://localhost:5000/admin</code> — Acceder al panel admin interno</li>
                <li class="mb-1">• <code>http://169.254.169.254/latest/meta-data/</code> — Metadata de nube (AWS)</li>
                <li class="mb-1">• <code>http://192.168.1.1</code> — Router/firewall de la red interna</li>
                <li class="mb-1">• <code>http://10.0.0.5:1433</code> — Escanear puerto de SQL Server</li>
                <li class="mb-1">• <code>http://127.0.0.1:8080</code> — Servicios internos en loopback</li>
            </ul>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="SsrfSeguro" asp-action="Index" class="btn btn-success">
            <i class="bi bi-shield-check"></i> Ver Versión Segura
        </a>
    </div>
</div>
