@model IEnumerable<MUNIDENUNCIA.Models.Denuncia>

@{
    ViewData["Title"] = "Resultados de Búsqueda";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-12">
            
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h2 class="mb-0">
                                <i class="fas fa-search-plus"></i>
                                Resultados de Búsqueda
                            </h2>
                            @if (ViewBag.CriterioBusqueda != null)
                            {
                                <p class="mb-0 mt-2">
                                    <small>Criterio: @ViewBag.CriterioBusqueda</small>
                                </p>
                            }
                        </div>
                        <div class="col-md-4 text-right">
                            <a asp-action="Buscar" class="btn btn-light">
                                <i class="fas fa-search"></i> Nueva Búsqueda
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    
                    @if (Model != null && Model.Any())
                    {
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle"></i>
                            Se encontraron <strong>@ViewBag.CantidadResultados resultados</strong> que coinciden con su búsqueda.
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover table-striped">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 60px;">ID</th>
                                        <th>Ciudadano</th>
                                        <th>Cédula</th>
                                        <th>Categoría</th>
                                        <th>Ubicación</th>
                                        <th style="width: 120px;">Fecha</th>
                                        <th style="width: 130px;">Estado</th>
                                        <th style="width: 100px;" class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var denuncia in Model)
                                    {
                                        <tr>
                                            <td class="font-weight-bold">#@denuncia.Id</td>
                                            <td>@denuncia.NombreCompleto</td>
                                            <td>@denuncia.Cedula</td>
                                            <td>
                                                <span class="badge badge-secondary">
                                                    @denuncia.Categoria
                                                </span>
                                            </td>
                                            <td>
                                                <small>@(denuncia.Ubicacion.Length > 50 ? denuncia.Ubicacion.Substring(0, 50) + "..." : denuncia.Ubicacion)</small>
                                            </td>
                                            <td>
                                                <small>@denuncia.FechaCreacion.ToString("dd/MM/yyyy")</small>
                                            </td>
                                            <td>
                                                @switch (denuncia.Estado)
                                                {
                                                    case "Pendiente":
                                                        <span class="badge badge-warning">
                                                            <i class="fas fa-clock"></i> Pendiente
                                                        </span>
                                                        break;
                                                    case "EnRevision":
                                                        <span class="badge badge-info">
                                                            <i class="fas fa-eye"></i> En Revisión
                                                        </span>
                                                        break;
                                                    case "Resuelta":
                                                        <span class="badge badge-success">
                                                            <i class="fas fa-check-circle"></i> Resuelta
                                                        </span>
                                                        break;
                                                    case "Cerrada":
                                                        <span class="badge badge-secondary">
                                                            <i class="fas fa-ban"></i> Cerrada
                                                        </span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-center">
                                                <a asp-action="Details" 
                                                   asp-route-id="@denuncia.Id" 
                                                   class="btn btn-sm btn-info"
                                                   title="Ver Detalles">
                                                    <i class="fas fa-eye"></i> Ver
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (Model.Count() > 1)
                        {
                            <div class="row mt-4">
                                <div class="col-md-12">
                                    <div class="card bg-light">
                                        <div class="card-body">
                                            <h6 class="card-title">
                                                <i class="fas fa-chart-pie"></i> Distribución por Estado
                                            </h6>
                                            <div class="row text-center mt-3">
                                                <div class="col-md-3">
                                                    <div class="h4 text-warning">
                                                        @Model.Count(d => d.Estado == "Pendiente")
                                                    </div>
                                                    <small>Pendientes</small>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="h4 text-info">
                                                        @Model.Count(d => d.Estado == "EnRevision")
                                                    </div>
                                                    <small>En Revisión</small>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="h4 text-success">
                                                        @Model.Count(d => d.Estado == "Resuelta")
                                                    </div>
                                                    <small>Resueltas</small>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="h4 text-secondary">
                                                        @Model.Count(d => d.Estado == "Cerrada")
                                                    </div>
                                                    <small>Cerradas</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-warning text-center" role="alert">
                            <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
                            <h4>No se encontraron resultados</h4>
                            <p class="mb-3">
                                No existen denuncias que coincidan con los criterios de búsqueda especificados.
                            </p>
                            <hr>
                            <p class="mb-0">
                                <strong>Sugerencias:</strong>
                            </p>
                            <ul class="text-left" style="max-width: 600px; margin: 0 auto;">
                                <li>Verifique que la cédula esté escrita correctamente</li>
                                <li>Asegúrese de que la categoría seleccionada sea correcta</li>
                                <li>Intente con otros criterios de búsqueda</li>
                            </ul>
                            <div class="mt-4">
                                <a asp-action="Buscar" class="btn btn-warning btn-lg">
                                    <i class="fas fa-redo"></i> Intentar Nueva Búsqueda
                                </a>
                                <a asp-action="Index" class="btn btn-secondary btn-lg ml-2">
                                    <i class="fas fa-list"></i> Ver Todas las Denuncias
                                </a>
                            </div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-light">
                    <a asp-action="Buscar" class="btn btn-primary">
                        <i class="fas fa-search"></i> Nueva Búsqueda
                    </a>
                    <a asp-action="Index" class="btn btn-secondary ml-2">
                        <i class="fas fa-list"></i> Ver Todas
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
