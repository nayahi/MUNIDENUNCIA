@model IEnumerable<MUNIDENUNCIA.Models.Denuncia>

@{
    ViewData["Title"] = "Denuncias Ciudadanas";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-12">
            
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h2 class="mb-0">
                                <i class="fas fa-list"></i>
                                Denuncias Ciudadanas
                            </h2>
                            <p class="mb-0 mt-2">Municipalidad de San José - Sistema de Gestión de Denuncias</p>
                        </div>
                        <div class="col-md-4 text-right">
                            <a asp-action="Create" class="btn btn-light btn-lg">
                                <i class="fas fa-plus-circle"></i> Nueva Denuncia
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["Mensaje"]
                            <button type="button" class="close" data-dismiss="alert">
                                <span>&times;</span>
                            </button>
                        </div>
                    }

                    <!-- Barra de herramientas -->
                    <div class="row mb-3">
                        <div class="col-md-8">
                            <a asp-action="Buscar" class="btn btn-outline-primary">
                                <i class="fas fa-search"></i> Búsqueda Avanzada
                            </a>
                            <a asp-action="Index" class="btn btn-outline-secondary ml-2">
                                <i class="fas fa-sync-alt"></i> Recargar
                            </a>
                        </div>
                        <div class="col-md-4 text-right">
                            <span class="badge badge-info badge-pill" style="font-size: 1.1em;">
                                Total: @Model.Count() denuncias
                            </span>
                        </div>
                    </div>

                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-striped">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 60px;">ID</th>
                                        <th>Ciudadano</th>
                                        <th>Cédula</th>
                                        <th>Categoría</th>
                                        <th>Ubicación</th>
                                        <th style="width: 120px;">Fecha</th>
                                        <th style="width: 130px;">Estado</th>
                                        <th style="width: 140px;" class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var denuncia in Model)
                                    {
                                        <tr>
                                            <td class="font-weight-bold">#@denuncia.Id</td>
                                            <td>@denuncia.NombreCompleto</td>
                                            <td>@denuncia.Cedula</td>
                                            <td>
                                                <span class="badge badge-secondary">
                                                    @denuncia.Categoria
                                                </span>
                                            </td>
                                            <td>
                                                <small>@(denuncia.Ubicacion.Length > 50 ? denuncia.Ubicacion.Substring(0, 50) + "..." : denuncia.Ubicacion)</small>
                                            </td>
                                            <td>
                                                <small>@denuncia.FechaCreacion.ToString("dd/MM/yyyy")</small>
                                            </td>
                                            <td>
                                                @switch (denuncia.Estado)
                                                {
                                                    case "Pendiente":
                                                        <span class="badge badge-warning">
                                                            <i class="fas fa-clock"></i> Pendiente
                                                        </span>
                                                        break;
                                                    case "EnRevision":
                                                        <span class="badge badge-info">
                                                            <i class="fas fa-eye"></i> En Revisión
                                                        </span>
                                                        break;
                                                    case "Resuelta":
                                                        <span class="badge badge-success">
                                                            <i class="fas fa-check-circle"></i> Resuelta
                                                        </span>
                                                        break;
                                                    case "Cerrada":
                                                        <span class="badge badge-secondary">
                                                            <i class="fas fa-ban"></i> Cerrada
                                                        </span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-center">
                                                <a asp-action="Details" 
                                                   asp-route-id="@denuncia.Id" 
                                                   class="btn btn-sm btn-info"
                                                   title="Ver Detalles">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                @if (denuncia.Estado == "Pendiente")
                                                {
                                                    <a asp-action="Edit" 
                                                       asp-route-id="@denuncia.Id" 
                                                       class="btn btn-sm btn-warning"
                                                       title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Resumen estadístico -->
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h5 class="card-title">
                                            <i class="fas fa-chart-bar"></i> Resumen por Estado
                                        </h5>
                                        <div class="row text-center">
                                            <div class="col-md-3">
                                                <div class="h3 text-warning">
                                                    @Model.Count(d => d.Estado == "Pendiente")
                                                </div>
                                                <small>Pendientes</small>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="h3 text-info">
                                                    @Model.Count(d => d.Estado == "EnRevision")
                                                </div>
                                                <small>En Revisión</small>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="h3 text-success">
                                                    @Model.Count(d => d.Estado == "Resuelta")
                                                </div>
                                                <small>Resueltas</small>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="h3 text-secondary">
                                                    @Model.Count(d => d.Estado == "Cerrada")
                                                </div>
                                                <small>Cerradas</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center" role="alert">
                            <i class="fas fa-info-circle fa-3x mb-3"></i>
                            <h4>No hay denuncias registradas</h4>
                            <p class="mb-3">
                                No existen denuncias ciudadanas en el sistema.
                            </p>
                            <a asp-action="Create" class="btn btn-primary btn-lg">
                                <i class="fas fa-plus-circle"></i> Registrar Primera Denuncia
                            </a>
                        </div>
                    }
                </div>

                <div class="card-footer bg-light text-muted">
                    <small>
                        <i class="fas fa-info-circle"></i>
                        Las denuncias se muestran ordenadas por fecha de creación (más recientes primero).
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            setTimeout(function() {
                $('.alert-success').fadeOut('slow');
            }, 5000);
        });
    </script>
}
