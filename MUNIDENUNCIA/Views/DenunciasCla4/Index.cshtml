@model IEnumerable<MUNIDENUNCIA.Models.Denuncia>

@{
    ViewData["Title"] = "Denuncias Ciudadanas";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2>
                    <i class="fas fa-bullhorn text-primary"></i>
                    Denuncias Ciudadanas
                </h2>

                @if (User.Identity.IsAuthenticated)
                {
                    <div>
                        @if (User.IsInRole("Ciudadano"))
                        {
                            <a asp-action="Create" class="btn btn-success">
                                <i class="fas fa-plus"></i> Nueva Denuncia
                            </a>
                        }
                        <span class="badge badge-info ml-2">
                            @User.Identity.Name
                        </span>
                    </div>
                }
                else
                {
                    <a asp-action="Create" class="btn btn-success">
                        <i class="fas fa-plus"></i> Registrar Denuncia
                    </a>
                }
            </div>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Mensaje"]
            <button type="button" class="close" data-dismiss="alert">
                <span>&times;</span>
            </button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            <button type="button" class="close" data-dismiss="alert">
                <span>&times;</span>
            </button>
        </div>
    }

    @if (User.IsInRole("Ciudadano"))
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            <strong>Mis Denuncias:</strong> A continuación se muestran únicamente las denuncias que usted ha registrado.
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>No hay denuncias registradas</strong>
            <p class="mb-0 mt-2">
                @if (User.IsInRole("Ciudadano"))
                {
                    <text>No ha registrado ninguna denuncia aún. Haga clic en "Nueva Denuncia" para crear una.</text>
                }
                else if (User.IsInRole("Funcionario") || User.IsInRole("Administrador"))
                {
                    <text>No hay denuncias en el sistema. Esperando que los ciudadanos registren denuncias.</text>
                }
                else
                {
                    <text>No hay denuncias disponibles. Puede registrar una nueva denuncia haciendo clic en el botón superior.</text>
                }
            </p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="thead-light">
                            <tr>
                                <th>ID</th>
                                <th>Categoría</th>
                                <th>Ubicación</th>
                                <th>Ciudadano</th>
                                <th>Estado</th>
                                <th>Fecha</th>
                                <th>Archivo</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>#@item.Id</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary text-white">
                                            @item.Categoria.ToString().Replace("_", " ")
                                        </span>
                                    </td>
                                    <td>
                                        @if (item.Ubicacion.Length > 40)
                                        {
                                            @item.Ubicacion.Substring(0, 40)
                                
                                            @:...
                                        }
                                        else
                                        {
                                            @item.Ubicacion
                                        }
                                    </td>
                                    <td>
                                        @item.NombreCompleto
                                        @if (User.IsInRole("Funcionario") || User.IsInRole("Administrador"))
                                        {
                                            <br />
                                            <small class="text-muted">
                                                <i class="fas fa-id-card"></i> @item.Cedula
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        @switch (item.Estado)
                                        {
                                            case "Recibida":
                                                <span class="badge bg-info text-white">@item.Estado</span>
                                                break;
                                            case "EnProceso":
                                                <span class="badge bg-warning text-dark">En Proceso</span>
                                                break;
                                            case "Resuelta":
                                                <span class="badge bg-success text-white">Resuelta</span>
                                                break;
                                            case "Rechazada":
                                                <span class="badge bg-danger text-white">Rechazada</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary text-white">@item.Estado</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @item.FechaCreacion.ToString("dd/MM/yyyy")
                                        <br />
                                        <small class="text-muted">@item.FechaCreacion.ToString("HH:mm")</small>
                                    </td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(item.ArchivoNombreOriginal))
                                        {
                                            <a asp-action="DescargarArchivo" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-danger"
                                               title="Descargar @item.ArchivoNombreOriginal">
                                                <i class="fas fa-file-pdf"></i>
                                                <i class="fas fa-download"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-info text-white" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>

                                            @if (User.IsInRole("Funcionario") || User.IsInRole("Administrador"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id"
                                                   class="btn btn-sm btn-warning text-dark" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>

                                                <a asp-action="CambiarEstado" asp-route-id="@item.Id"
                                                   class="btn btn-sm btn-primary text-white" title="Cambiar estado">
                                                    <i class="fas fa-exchange-alt"></i>
                                                </a>
                                            }

                                            @if (User.IsInRole("Administrador"))
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.Id"
                                                   class="btn btn-sm btn-danger text-white" title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                Total de denuncias: <strong>@Model.Count()</strong>

                @if (User.IsInRole("Funcionario") || User.IsInRole("Administrador"))
                {
                    <span class="ml-3">
                        Recibidas: <span class="badge badge-info">@Model.Count(d => d.Estado == "Recibida")</span>
                    </span>
                    <span class="ml-2">
                        En Proceso: <span class="badge badge-warning">@Model.Count(d => d.Estado == "EnProceso")</span>
                    </span>
                    <span class="ml-2">
                        Resueltas: <span class="badge badge-success">@Model.Count(d => d.Estado == "Resuelta")</span>
                    </span>
                }
            </p>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Auto-ocultar alertas después de 5 segundos
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}
