@*
    Views/Auditoria/Logs.cshtml
    Semana 3 - A09: Listado filtrable y paginado de AuditLogs
*@
@model MUNIDENUNCIA.ViewModels.LogsAuditoriaViewModel
@{
    ViewData["Title"] = "Logs de auditoría";
}

<h2>@ViewData["Title"]</h2>
<p class="text-muted">Mostrando @Model.Eventos.Count de @Model.TotalEventos eventos totales.</p>

<!-- =========================================================================
     Formulario de filtros
     ========================================================================= -->
<form asp-action="Logs" method="get" class="card card-body mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label">Tipo de evento</label>
            <select name="tipo" class="form-select">
                <option value="">(todos)</option>
                @foreach (var t in Model.TiposDisponibles)
                {
                    <option value="@t" selected="@(t == Model.FiltroTipo)">@t</option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Usuario</label>
            <input name="usuario" class="form-control" value="@Model.FiltroUsuario"
                   placeholder="Email o ID parcial" />
        </div>

        <div class="col-md-2">
            <label class="form-label">IP</label>
            <input name="ip" class="form-control" value="@Model.FiltroIp"
                   placeholder="192.168.1.1" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Desde <small class="text-muted">(UTC)</small></label>
            <input name="desde" type="datetime-local" class="form-control"
                   value="@(Model.FiltroDesde?.ToString("yyyy-MM-ddTHH:mm"))" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Hasta <small class="text-muted">(UTC)</small></label>
            <input name="hasta" type="datetime-local" class="form-control"
                   value="@(Model.FiltroHasta?.ToString("yyyy-MM-ddTHH:mm"))" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Filtrar</button>
        <a asp-action="Logs" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

<!-- =========================================================================
     Tabla de eventos
     ========================================================================= -->
<table class="table table-sm table-hover">
    <thead>
        <tr>
            <th>Timestamp</th>
            <th>Tipo</th>
            <th>Usuario</th>
            <th>IP</th>
            <th>Éxito</th>
            <th>Descripción</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ev in Model.Eventos)
        {
            <tr class="@(ev.Success ? "" : "table-warning")">
                <td>@ev.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                <td><code>@ev.EventType</code></td>
                <td>@(ev.UserId ?? "-")</td>
                <td>@ev.IpAddress</td>
                <td>@(ev.Success ? "✓" : "✗")</td>
                <td>@ev.Description</td>
            </tr>
        }
    </tbody>
</table>

<!-- =========================================================================
     Paginación
     ========================================================================= -->
@if (Model.TotalPaginas > 1)
{
    <nav>
        <ul class="pagination">
            @if (Model.Pagina > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Logs"
                       asp-route-pagina="@(Model.Pagina - 1)"
                       asp-route-tipo="@Model.FiltroTipo"
                       asp-route-usuario="@Model.FiltroUsuario"
                       asp-route-ip="@Model.FiltroIp"
                       asp-route-desde="@Model.FiltroDesde"
                       asp-route-hasta="@Model.FiltroHasta">Anterior</a>
                </li>
            }

            <li class="page-item active">
                <span class="page-link">
                    Página @Model.Pagina de @Model.TotalPaginas
                </span>
            </li>

            @if (Model.Pagina < Model.TotalPaginas)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Logs"
                       asp-route-pagina="@(Model.Pagina + 1)"
                       asp-route-tipo="@Model.FiltroTipo"
                       asp-route-usuario="@Model.FiltroUsuario"
                       asp-route-ip="@Model.FiltroIp"
                       asp-route-desde="@Model.FiltroDesde"
                       asp-route-hasta="@Model.FiltroHasta">Siguiente</a>
                </li>
            }
        </ul>
    </nav>
}
