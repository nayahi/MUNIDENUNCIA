@model MUNIDENUNCIA.ViewModels.CrearDenunciaViewModel

@{
    ViewData["Title"] = "Crear Denuncia - VULNERABLE";
}

<div class="container mt-4">
    <div class="alert alert-danger">
        <h4><i class="fas fa-exclamation-triangle"></i> Formulario Vulnerable</h4>
        <p><strong>Falta:</strong> Token CSRF, validación del lado servidor</p>
    </div>

    <div class="card">
        <div class="card-header bg-warning">
            <h3>Crear Denuncia (Versión Insegura)</h3>
        </div>
        <div class="card-body">
            <!-- NOTA: Sin @Html.AntiForgeryToken() -->
            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div class="form-group">
                    <label asp-for="Cedula">Cédula</label>
                    <input asp-for="Cedula" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="NombreCompleto">Nombre Completo</label>
                    <input asp-for="NombreCompleto" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="Email">Email</label>
                    <input asp-for="Email" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="Telefono">Teléfono</label>
                    <input asp-for="Telefono" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="Categoria">Categoría</label>
                    <select asp-for="Categoria" class="form-control"
                            asp-items="Html.GetEnumSelectList<MUNIDENUNCIA.Models.CategoriaDenuncia>()">
                        <option value="">Seleccione...</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Ubicacion">Ubicación</label>
                    <input asp-for="Ubicacion" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="Descripcion">Descripción</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
                </div>

                <div class="form-group">
                    <label asp-for="ArchivoPdf">Archivo PDF (Sin validación)</label>
                    <input asp-for="ArchivoPdf" type="file" class="form-control-file" />
                </div>

                <button type="submit" class="btn btn-primary">Registrar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>