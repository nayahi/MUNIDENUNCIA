@model MUNIDENUNCIA.ViewModels.VerifyMfaViewModel

@{
    ViewData["Title"] = "Verificación de Dos Factores";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">Verificación de Seguridad</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <strong>Autenticación de Dos Factores</strong>
                    <p class="mb-0">
                        Ingrese el código de verificación de 6 dígitos
                        de su aplicación de autenticación.
                    </p>
                </div>

                <form asp-action="VerifyMfa" method="post">
                    <div asp-validation-summary="All"
                         class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="VerificationCode"
                               class="form-label"></label>
                        <input asp-for="VerificationCode"
                               class="form-control form-control-lg text-center"
                               maxlength="6"
                               placeholder="000000"
                               style="letter-spacing: 10px; font-size: 24px;" />
                        <span asp-validation-for="VerificationCode"
                              class="text-danger"></span>
                    </div>

                    <div class="alert alert-warning">
                        <small>
                            <strong>Simulación para esta tarea:</strong><br>
                            Use el código <strong>123456</strong> para verificar.
                            En producción, este código vendría de Google Authenticator
                            u otra aplicación MFA.
                        </small>
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        Verificar Código
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
