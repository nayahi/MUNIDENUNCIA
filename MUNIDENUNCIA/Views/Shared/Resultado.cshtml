@*
    Views/Shared/Resultado.cshtml
    (También puede ir en Views/SsrfVulnerable/ y Views/SsrfSeguro/)
    Vista de resultado para demos de SSRF (A10)
*@

@{
    ViewData["Title"] = "Resultado SSRF (A10)";
    var url = ViewBag.Url as string ?? "";
    var error = ViewBag.Error as string;
    var contenido = ViewBag.Contenido as string;
    var statusCode = ViewBag.StatusCode;
    var servicio = ViewBag.Servicio as string;
}

<div class="container mt-4">
    <h2>
        <i class="bi bi-globe"></i> Resultado de Petición
    </h2>
    <hr />

    <p><strong>URL solicitada:</strong> <code>@url</code></p>

    @if (servicio != null)
    {
        <p><strong>Servicio autorizado:</strong> @servicio</p>
    }

    @if (error != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-x-circle-fill"></i> @error
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Código de respuesta:</strong> @statusCode
        </div>

        @if (!string.IsNullOrEmpty(contenido))
        {
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    Contenido recibido (primeros caracteres)
                </div>
                <div class="card-body">
                    <pre class="mb-0" style="max-height:400px;overflow-y:auto;"><code>@contenido</code></pre>
                </div>
            </div>
        }
    }

    <div class="mt-3">
        <a asp-controller="SsrfVulnerable" asp-action="Index" class="btn btn-outline-danger me-2">
            Versión Vulnerable
        </a>
        <a asp-controller="SsrfSeguro" asp-action="Index" class="btn btn-outline-success">
            Versión Segura
        </a>
    </div>
</div>
