<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MUNIDENUNCIA</title>

    @* <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous"> *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/MUNIDENUNCIA.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-building"></i> MUNIDENUNCIA
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Permisos" asp-action="Index">
                                <i class="fas fa-home"></i> Permisos sin vulnerabilidad
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Permisosvulnerable" asp-action="Index">
                                <i class="fas fa-home"></i> Permisos CON vulnerabilidad
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Denuncias" asp-action="Index">
                                <i class="fas fa-home"></i> Denuncias CON vulnerabilidad Clase 3
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="DenunciasCla4Vulnerable" asp-action="Index">
                                <i class="fas fa-home"></i> Denuncias CON vulnerabilidad Clase 4
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="DenunciasCla4" asp-action="Index">
                                <i class="fas fa-home"></i> Denuncias SIN vulnerabilidad Clase 4 (OK)
                            </a>
                        </li>
                        @* <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">
                                <i class="fas fa-shield-alt"></i> Privacidad
                            </a>
                        </li> *@
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            <div class="row py-4">
                <div class="col-md-6">
                    <h6><i class="fas fa-building"></i> Sistema de Información Municipal</h6>
                    <p class="small mb-0">
                        Su Municipalidad<br />
                        República de Costa Rica
                    </p>
                </div>
                <div class="col-md-6 text-end">
                    <p class="small mb-0">
                        &copy; 2025 - MUNIDENUNCIA - Su Municipalidad<br />
                        <a asp-controller="Home" asp-action="Privacy">Política de Privacidad</a>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @* <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script> *@
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>